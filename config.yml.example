vote_no: "❌"

# Optionaler zweiter Account für Poll-Versand (WA-Bridge-Workaround)
# Polls werden von diesem User gesendet damit die WA-Bridge sie akzeptiert.
# Leer lassen wenn nicht benötigt.
poll_sender_id: "@phil:matrix.srz.one"
poll_sender_password: "dein-phil-passwort"
