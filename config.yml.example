homeserver: "https://matrix.srz.one"
user_id: "@teambot:matrix.srz.one"
password: "dein-bot-passwort"
room_id: "!HAUPTRAUM-ID:matrix.srz.one"
admin_room_id: "!ADMIN-RAUM-ID:matrix.srz.one"

db_path: "data/teambot.db"

# Spieltag-Einstellungen
vote_weekday: 5    # 0=Mo … 6=So (5=Samstag)
